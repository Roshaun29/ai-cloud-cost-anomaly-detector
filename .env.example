APP_NAME=FastAPI Auth Service
APP_ENV=development
APP_DEBUG=false

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=fastapi_auth

JWT_SECRET_KEY=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET_KEY=replace-with-a-different-long-random-refresh-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

AWS_REGION=us-east-1
ANOMALY_CONTAMINATION=0.1
ANOMALY_ZSCORE_THRESHOLD=2.5
ANOMALY_MIN_SAMPLES_PER_SERVICE=5
